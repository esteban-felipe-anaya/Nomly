# Nomly Flutter app — runtime config (loaded by flutter_dotenv).
# API base URL the app talks to. Switch between the Django backend and the mock here.

# Django backend (real)
# NOMLY_API_BASE_URL=http://localhost:8000

# Alternatives (uncomment one):
# NOMLY_API_BASE_URL=http://10.0.2.2:8000      # Android emulator -> host backend
NOMLY_API_BASE_URL=http://192.168.6.124:8000 # physical device on your LAN
# NOMLY_API_BASE_URL=http://localhost:3000      # json-server mock
