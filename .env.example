# Copy to .env and set the API base URL the app should use.
# Resolution order: --dart-define=NOMLY_API_BASE_URL  >  this .env  >  platform default.

# Django backend:        http://localhost:8000   (Android emulator: http://10.0.2.2:8000)
# json-server mock:      http://localhost:3000
NOMLY_API_BASE_URL=http://localhost:8000
